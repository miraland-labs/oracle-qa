# ============================================================================
# Oracle QA — Configuration
# ============================================================================
# Copy to .env and fill in your values.

# --- Solana ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Oracle operator keypair (signs ConfirmOracle transactions)
ORACLE_KEYPAIR_PATH=$HOME/.config/solana/oracle-keypair.json

# SLA-Escrow program ID (deployed on Devnet)
ESCROW_PROGRAM_ID=Escr441mZ9BoZxFjAENegAH3xy1zcYtUcv4FWcZhp9yr

# --- HTTP Server ---
BIND_ADDR=127.0.0.1:4020

# --- Evaluation ---
# Max time (ms) the oracle allows for its own evaluation before giving up
EVALUATION_TIMEOUT_MS=30000

# Registry base URL for fetching SLA documents and delivery evidence by hash
# The oracle fetches: GET {EVIDENCE_REGISTRY_URL}/{hex_hash}
EVIDENCE_REGISTRY_URL=http://localhost:4021

# --- Logging ---
RUST_LOG=oracle_qa=info,tower_http=info
