# Copy to .env and adjust for your deployment (e.g. /etc/oracle-qa.env on VPS).

# Solana RPC / WebSocket (must match the cluster where ESCROW_PROGRAM_ID is deployed)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Oracle operator keypair (must match `oracle_authority` chosen at FundPayment time)
ORACLE_KEYPAIR_PATH=/path/to/oracle-keypair.json

# SLA-Escrow program (defaults to crate `sla_escrow_api::ID` if unset)
# ESCROW_PROGRAM_ID=

# HTTP API bind (behind nginx use 127.0.0.1:4020)
BIND_ADDR=0.0.0.0:4020

# Max time for fetch + evaluate + settle per job
EVALUATION_TIMEOUT_MS=30000

# Evidence registry base URL — GET {URL}/{64-char-hex-sha256} must return **raw bytes** that hash to that value
EVIDENCE_REGISTRY_URL=https://your-registry.example.com/evidence

# Optional: comma-separated mirror base URLs (tried in order; first response whose body hashes correctly wins)
# EVIDENCE_REGISTRY_URLS=https://primary.example.com/evidence,https://mirror.example.com/evidence

# Optional: Authorization header sent on every registry GET (e.g. Bearer token)
# EVIDENCE_REGISTRY_AUTH_HEADER=Bearer your-token

# Registry fetch resilience (transient HTTP errors only; hash mismatch always fails)
# EVIDENCE_FETCH_MAX_RETRIES=3
# EVIDENCE_FETCH_RETRY_BASE_MS=200

# Production ledger (PostgreSQL). Run migrations/init.sql before enabling.
# DATABASE_URL=postgres://user:password@host:5432/oracle_qa

# Manual evaluation control plane. Prefer the SHA-256 hex form in production.
# ORACLE_OPERATOR_TOKEN_SHA256=<64_HEX_CHARS>
# ORACLE_OPERATOR_TOKEN=dev-only-operator-token
# ORACLE_ALLOW_UNAUTHENTICATED_MANUAL_EVALUATE=false
# ORACLE_MANUAL_EVALUATE_RATE_LIMIT=30
# ORACLE_MANUAL_EVALUATE_RATE_WINDOW_MS=60000

# CORS defaults to no browser origins. Set explicit operator consoles only.
# ORACLE_CORS_ALLOWED_ORIGINS=https://ops.example.com

# Production evaluation policy
# ORACLE_STRICT_PROFILE=true
# ORACLE_DEAD_LETTER_MAX_ATTEMPTS=5
# ORACLE_JOB_CHANNEL_CAPACITY=256

# Logging
RUST_LOG=oracle_qa=info,tower_http=info
